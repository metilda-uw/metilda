    "@types/cash": "0.0.3",
    "@types/chai": "^4.3.20",
    "@types/d3-scale": "^4.0.9",
    "@types/enzyme": "^3.10.18",
    "@types/file-saver": "^2.0.7",
    "@types/jest": "^29.5.14",
    "@types/jquery": "^3.5.32",
    "@types/materialize-css": "^1.0.14",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/react-file-reader-input": "^1.1.4",
    "@types/react-redux": "^7.1.34",
    "@types/react-router": "^5.1.20",
    "@types/react-router-dom": "^5.3.3",
    "@types/react-select": "^3.1.0",
    "@types/recompose": "^0.30.15",
    "@types/sinon": "^17.0.3",
    "@types/sizzle": "^2.3.9",
    "@types/styled-components": "^5.1.34",
    "axios": "^1.7.9",
    "chai": "^4.5.0",
    "chai-enzyme": "^1.0.0-beta.1",
    "chart.js": "^2.9.4",
    "cheerio": "1.0.0-rc.12",
    "d3": "^7.9.0",
    "d3-scale": "^4.0.2",
    "enzyme": "^3.11.0",
    "file-saver": "^2.0.5",
    "firebase": "^11.1.0",
    "font-awesome": "^4.7.0",
    "immutability-helper": "^3.1.1",
    "jquery": "^3.7.1",
    "js-file-download": "^0.4.12",
    "konva": "^9.3.16",
    "materialize-css": "^1.0.0",
    "moment": "^2.30.1",
    "npm-run-all": "^4.1.5",
    "query-string": "^7.1.3",
    "react": "^18.3.1",
    "react-chartjs-2": "^2.11.2",
    "react-dom": "^18.3.1",
    "react-file-reader": "^1.1.4",
    "react-file-reader-input": "^2.0.0",
    "react-firebase-hooks": "^5.1.1",
    "react-fontawesome": "^1.7.1",
    "react-ga": "^3.3.1",
    "react-https-redirect": "^1.1.0",
    "react-konva": "^18.2.10",
    "react-media-player": "^0.7.9",
    "react-modal": "^3.16.1",
    "react-notifications": "^1.7.4",
    "react-pie-menu": "^0.2.4",
    "react-redux": "^8.1.3",
    "react-router-dom": "^5.3.4",
    "react-scripts": "5.0.1",
    "react-select": "^3.2.0",
    "recompose": "^0.30.0",
    "recorder-js": "^1.0.7",
    "redux": "^4.2.1",
    "redux-thunk": "^2.4.2",
    "sass": "^1.81.0",
    "sinon": "^17.0.1",
    "styled-components": "^5.3.11",
    "tone": "^13.4.9",
    "tslint": "^6.1.3",
    "typescript": "^5.6.3",
    "xlsx": "^0.18.5"
  },
  "scripts": {
    "build-css": "sass --no-source-map --load-path=./src --load-path=./node_modules src:src",
    "watch-css": "npm run build-css && sass --no-source-map --load-path=./src --load-path=./node_modules src:src --watch",
    "start": "npm-run-all -p watch-css start-js",
    "start-js": "craco start",
    "tslint": "tslint -p tsconfig.json -c tslint.json src/**/*.{ts,tsx}",
    "build": "npm run build-css && craco build",
    "test": "npm run tslint && npm run build-css && craco test",
    "coveralls": "npm run tslint && npm run build-css && craco test --coverage --coverageReporters=text-lcov | coveralls",
    "eject": "react-scripts eject"
  },
  "jest": {
    "coverageReporters": [
      "text",
      "html"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "src/**/*.jsx",
      "src/**/*.tsx",
      "src/**/*.ts",
      "!src/Lib/**/*.js",
      "!src/serviceWorker.js"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(konva|fast-check|pure-rand)).*\\.js$"
    ],
    "moduleNameMapper": {
      "^pure-rand/(.*)$": "<rootDir>/node_modules/pure-rand/lib/$1.js"
    }
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not ie <= 11",
    "not op_mini all"
  ],
  "proxy": "http://localhost:5000",
  "devDependencies": {
    "@cfaester/enzyme-adapter-react-18": "^0.8.0",
    "@craco/craco": "^7.1.0",
    "@types/chai-enzyme": "^0.6.12",
    "fake-indexeddb": "^6.2.5",
    "fast-check": "^4.7.0"
  },
  "overrides": {
    "cheerio": "1.0.0-rc.12",
    "fork-ts-checker-webpack-plugin": {
      "ajv": "^6.12.6",
      "ajv-keywords": "^3.5.2",
      "schema-utils": "^2.7.1"
    }
  }
}
